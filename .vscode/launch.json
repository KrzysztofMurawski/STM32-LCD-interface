{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "STM32 Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/TestProject.elf",

            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f1x.cfg"
            ],

            "device": "STM32F103C8",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none"

        }
    ]
}